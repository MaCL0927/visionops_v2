# VisionOps Modbus TCP Server v1.1
# 3576 作为 Modbus TCP Server，电脑/上位机作为 Modbus TCP Client。

VISIONOPS_MODBUS_TCP_ENABLE=1

# 监听地址与端口
# 0.0.0.0 表示监听所有网卡，例如 eth0:192.168.1.202
# 开发测试建议使用 1502，避免占用标准低端口 502
VISIONOPS_MODBUS_TCP_HOST=0.0.0.0
VISIONOPS_MODBUS_TCP_PORT=1502

# Modbus Unit ID / Slave ID
# Modbus TCP 通常仍保留 Unit ID，默认用 1，和 RTU 的 slave_id 保持一致
VISIONOPS_MODBUS_TCP_UNIT_ID=1

# 寄存器数量（v1.2 register_map_v2 默认 300）与最大目标数
VISIONOPS_MODBUS_TCP_REGISTER_COUNT=300
VISIONOPS_MODBUS_TCP_MAX_OBJECTS=5

# 读取 VisionOps 最新检测结果的接口
VISIONOPS_RESULT_URL=http://127.0.0.1:8090/api/cpp/stream/latest_result

# 多久刷新一次检测结果到寄存器
VISIONOPS_MODBUS_TCP_POLL_INTERVAL_MS=100

# NG 判定逻辑：
# 留空：默认 object_count > 0 时 ng_flag=1
# 指定类别：例如 1,2,3 表示检测到 class_id 为 1/2/3 时 ng_flag=1
VISIONOPS_MODBUS_TCP_NG_CLASS_IDS=

# 日志级别
VISIONOPS_MODBUS_TCP_LOG_LEVEL=INFO
