# 是否启用
VISIONOPS_MODBUS_ENABLE=1

# 3576 盒子上的 RS-485 串口设备
# 需要根据实际设备修改，例如 /dev/ttyS3、/dev/ttyS4、/dev/ttyAMA0
VISIONOPS_MODBUS_SERIAL=/dev/ttyS5

# Modbus RTU 参数
VISIONOPS_MODBUS_SLAVE_ID=1
VISIONOPS_MODBUS_BAUDRATE=9600
VISIONOPS_MODBUS_PARITY=N
VISIONOPS_MODBUS_BYTESIZE=8
VISIONOPS_MODBUS_STOPBITS=1

# 寄存器数量（v1.2 register_map_v2 默认 300）
VISIONOPS_MODBUS_REGISTER_COUNT=300
VISIONOPS_MODBUS_MAX_OBJECTS=5

# 读取 VisionOps 最新检测结果的接口
VISIONOPS_RESULT_URL=http://127.0.0.1:8090/api/cpp/stream/latest_result

# 多久刷新一次检测结果到寄存器
VISIONOPS_MODBUS_POLL_INTERVAL_MS=100

# NG 判定逻辑：
# 留空：默认 object_count > 0 时 ng_flag=1
# 指定类别：例如 1,2,3 表示检测到 class_id 为 1/2/3 时 ng_flag=1
VISIONOPS_MODBUS_NG_CLASS_IDS=

# 日志级别
VISIONOPS_MODBUS_LOG_LEVEL=INFO
